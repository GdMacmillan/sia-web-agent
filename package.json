{
  "name": "@sia-web/agent",
  "version": "0.3.3",
  "description": "SIA agent runtime — a LangGraph deep-agent with prompts, skills, and tool middleware. Extracted from sia-web.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gdmacmillan/sia-web-agent.git"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "test": "jest --testPathPatterns='tests/(unit|integration|debugging)' --testPathIgnorePatterns='integration'",
    "test:unit": "jest --testPathPatterns='tests/(unit|integration|debugging)' --testPathIgnorePatterns='integration'",
    "test:integration": "RUN_INTEGRATION=true jest tests/integration --forceExit",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@huggingface/inference": "4.13.15",
    "@langchain/community": "1.1.28",
    "@langchain/core": "1.1.46",
    "@langchain/langgraph": "1.3.0",
    "@langchain/langgraph-checkpoint": "1.0.2",
    "@langchain/mcp-adapters": "1.1.3",
    "@langchain/openai": "1.4.5",
    "@langchain/openrouter": "0.2.4",
    "@tavily/core": "0.7.2",
    "@vscode/ripgrep": "1.17.1",
    "axios": "1.13.5",
    "dotenv": "17.4.1",
    "fast-glob": "3.3.1",
    "langchain": "1.4.0",
    "langsmith": "0.7.1",
    "micromatch": "4.0.8",
    "openai": "6.37.0",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "safe-regex": "^2.1.1",
    "tsx": "^4.20.6",
    "uuid": "13.0.0",
    "zod": "4.3.5"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.4.1",
    "@langchain/tavily": "^1.0.0",
    "@types/jest": "^30.0.0",
    "@types/micromatch": "^4.0.10",
    "@types/node": "^25.3.3",
    "@types/safe-regex": "^1.1.6",
    "@types/uuid": "^11.0.0",
    "babel-jest": "^30.3.0",
    "eslint": "^10.3.0",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^16.4.0",
    "jest": "^30.4.2",
    "ts-jest": "29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.59.3"
  }
}
