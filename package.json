{
  "name": "@sia-web/agent",
  "version": "0.3.3",
  "description": "SIA agent runtime — a LangGraph deep-agent with prompts, skills, and tool middleware. Extracted from sia-web.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gdmacmillan/sia-web-agent.git"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "test": "jest --testPathPatterns='tests/(unit|integration|debugging)' --testPathIgnorePatterns='integration|tests/unit/code-interpreter' && yarn test:interpreter",
    "test:unit": "jest --testPathPatterns='tests/(unit|integration|debugging)' --testPathIgnorePatterns='integration|tests/unit/code-interpreter'",
    "test:interpreter": "NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.interpreter.js",
    "test:integration": "RUN_INTEGRATION=true jest tests/integration --forceExit",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@huggingface/inference": "4.13.15",
    "@jitl/quickjs-ng-wasmfile-release-asyncify": "^0.32.0",
    "@langchain/community": "1.1.28",
    "@langchain/core": "1.1.46",
    "@langchain/langgraph": "1.3.0",
    "@langchain/langgraph-checkpoint": "1.0.2",
    "@langchain/mcp-adapters": "1.1.3",
    "@langchain/openai": "1.4.5",
    "@langchain/openrouter": "0.2.4",
    "@sveltejs/acorn-typescript": "^1.0.9",
    "@tavily/core": "0.7.2",
    "@vscode/ripgrep": "1.17.1",
    "acorn": "^8.16.0",
    "axios": "1.18.1",
    "dedent": "^1.7.1",
    "dotenv": "17.4.2",
    "estree-walker": "^3.0.3",
    "fast-glob": "3.3.3",
    "json-schema-to-typescript": "^15.0.4",
    "langchain": "1.4.0",
    "langsmith": "0.7.1",
    "magic-string": "^0.30.21",
    "micromatch": "4.0.8",
    "openai": "6.37.0",
    "p-queue": "^9.3.0",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "quickjs-emscripten": "^0.32.0",
    "quickjs-emscripten-core": "^0.32.0",
    "safe-regex": "^2.1.1",
    "tsx": "^4.23.1",
    "uuid": "13.0.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.4.1",
    "@langchain/tavily": "^1.0.0",
    "@types/estree": "^1.0.9",
    "@types/jest": "^30.0.0",
    "@types/micromatch": "^4.0.10",
    "@types/node": "^25.3.3",
    "@types/safe-regex": "^1.1.6",
    "@types/uuid": "^11.0.0",
    "babel-jest": "^30.3.0",
    "eslint": "^10.7.0",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^17.7.0",
    "jest": "^30.4.2",
    "ts-jest": "29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.64.0"
  }
}
