# LLM provider — defaults to openrouter
LLM_PROVIDER=openrouter

# OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Model tiers (override per role with *_MODEL vars if needed)
OPENROUTER_MIDTIER_MODEL=
OPENROUTER_SMALL_FAST_MODEL=
OPENROUTER_HEAVY_THINKING_MODEL=

# ---------------------------------------------------------------------------
# Optional — host runtime contract
#
# When the agent is run inside a host (siad, etc.) the host injects these at
# spawn time so the agent can announce itself and emit telemetry. They are
# unnecessary for standalone use and can be left unset.
#
# SIA_WORKSPACE_ID=
# SIA_AGENT_ID=
# SIAD_EVENTS_URL=         # loopback POST endpoint for usage events
# SIAD_LOCAL_TOKEN=        # bearer token paired with SIAD_EVENTS_URL
#
# Full reference: docs/HOST_CONTRACT.md
# ---------------------------------------------------------------------------
